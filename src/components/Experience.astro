---
import { experience } from "../data/content";
import T from "./T.astro";
const pad2 = (n: number) => String(n + 1).padStart(2, "0");
---
<section class="section experience" id="experiencia">
  <div class="container">
    <div class="sec-head reveal">
      <span class="sec-index">02</span>
      <h2 class="sec-title"><T es={experience.title.es} en={experience.title.en} /></h2>
      <span class="sec-rule"></span>
    </div>

    <ol class="timeline">
      {experience.jobs.map((job, i) => (
        <li class="job reveal" style={`--d:${i * 80}ms`}>
          <div class="job-node">
            <span class="job-dot" class:list={[{ "is-current": job.current }]}></span>
            <span class="job-num">{pad2(i)}</span>
          </div>

          <div class="job-card">
            <div class="job-top">
              <div>
                <h3 class="job-role">
                  <T es={job.role.es} en={job.role.en} />
                  {job.current && <span class="now-tag"><T es="Actual" en="Now" /></span>}
                </h3>
                {job.promotedFrom && (
                  <p class="job-promo">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 19V5M6 11l6-6 6 6"/></svg>
                    <T es="Ascendido desde" en="Promoted from" />&nbsp;<strong><T es={job.promotedFrom.es} en={job.promotedFrom.en} /></strong>
                  </p>
                )}
                <p class="job-co">{job.company}</p>
              </div>
              <span class="job-period"><T es={job.period.es} en={job.period.en} /></span>
            </div>

            <p class="job-desc"><T es={job.desc.es} en={job.desc.en} block /></p>

            <ul class="job-tags">
              {job.tags.map((t) => <li class="tag">{t}</li>)}
            </ul>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .timeline { list-style: none; position: relative; }
  .timeline::before {
    content: "";
    position: absolute;
    left: 19px; top: 8px; bottom: 8px;
    width: 1px;
    background: linear-gradient(var(--line-2), var(--line), transparent);
  }
  .job {
    position: relative;
    display: grid;
    grid-template-columns: 40px 1fr;
    gap: clamp(1rem, 3vw, 2rem);
    padding-bottom: clamp(1.5rem, 4vw, 2.6rem);
  }
  .job:last-child { padding-bottom: 0; }

  .job-node {
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    padding-top: 0.4rem;
  }
  .job-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--bg);
    border: 2px solid var(--line-2);
    transition: border-color 0.3s var(--ease), box-shadow 0.3s var(--ease);
    z-index: 1;
  }
  .job-dot.is-current {
    border-color: var(--accent);
    background: var(--accent);
    box-shadow: 0 0 0 4px var(--accent-soft);
  }
  .job:hover .job-dot { border-color: var(--accent); }
  .job-num {
    font-size: 0.66rem; font-weight: 700; letter-spacing: 0.1em;
    color: var(--faint);
  }

  .job-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: clamp(1.2rem, 3vw, 1.8rem);
    background: var(--card);
    transition: border-color 0.35s var(--ease), background-color 0.35s var(--ease), transform 0.35s var(--ease);
  }
  .job:hover .job-card {
    border-color: var(--line-2);
    background: var(--card-hover);
    transform: translateX(4px);
  }

  .job-top {
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 1rem; flex-wrap: wrap; margin-bottom: 0.8rem;
  }
  .job-role {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.15rem, 2.4vw, 1.45rem);
    color: var(--text-strong);
    line-height: 1.2;
    display: flex; align-items: center; gap: 0.7rem; flex-wrap: wrap;
  }
  .now-tag {
    font-family: var(--font-body);
    font-size: 0.62rem; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase;
    color: #04101f; background: var(--accent);
    padding: 0.15rem 0.5rem; border-radius: 999px;
  }
  .job-promo {
    display: inline-flex; align-items: center; gap: 0.4rem;
    margin-top: 0.45rem;
    font-size: 0.82rem; font-weight: 500;
    color: var(--muted);
  }
  .job-promo svg { width: 13px; height: 13px; color: var(--accent-ink); }
  .job-promo strong { color: var(--text-strong); font-weight: 700; }
  .job-co { color: var(--accent-ink); font-weight: 600; font-size: 0.95rem; margin-top: 0.3rem; }
  .job-period {
    font-size: 0.8rem; font-weight: 600; letter-spacing: 0.04em;
    color: var(--muted);
    white-space: nowrap;
    padding-top: 0.2rem;
  }
  .job-desc { color: var(--text); font-weight: 300; line-height: 1.55; margin-bottom: 1.1rem; max-width: 62ch; }

  .job-tags { list-style: none; display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .tag {
    font-size: 0.78rem; font-weight: 600;
    color: var(--muted);
    border: 1px solid var(--line);
    border-radius: 7px;
    padding: 0.28rem 0.65rem;
    transition: color 0.25s var(--ease), border-color 0.25s var(--ease);
  }
  .job:hover .tag { color: var(--text-strong); border-color: var(--line-2); }

  @media (max-width: 540px) {
    .job { grid-template-columns: 28px 1fr; gap: 0.9rem; }
    .timeline::before { left: 13px; }
    .job-num { display: none; }
  }
</style>
