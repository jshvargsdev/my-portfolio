---
import { hero, profile } from "../data/content";
import T from "./T.astro";
---
<section class="hero" id="top">
  <!-- decorative crosshairs -->
  <span class="cross cross-tl" aria-hidden="true"></span>
  <span class="cross cross-br" aria-hidden="true"></span>

  <div class="container hero-inner">
    <p class="hero-kicker fade" style="--d:80ms">
      <span class="status">
        <span class="status-dot"></span>
        <T es={profile.available.es} en={profile.available.en} />
      </span>
    </p>

    <h1 class="hero-title">
      <span class="line fade" style="--d:160ms">{hero.headline1}</span>
      <span class="line outline fade" style="--d:280ms">{hero.headline2}
        <span class="role-tag">
          <T es={hero.kicker.es} en={hero.kicker.en} />
        </span>
      </span>
    </h1>

    <p class="hero-tag fade" style="--d:400ms">
      <T es={hero.tagline.es} en={hero.tagline.en} block />
    </p>

    <div class="hero-cta fade" style="--d:500ms">
      <a class="btn btn-primary" href="#contacto">
        <T es={hero.ctaPrimary.es} en={hero.ctaPrimary.en} />
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
      </a>
      <a class="btn btn-ghost" href={profile.cv} download>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v12M7 11l5 5 5-5M5 21h14"/></svg>
        <T es={hero.ctaSecondary.es} en={hero.ctaSecondary.en} />
      </a>
    </div>

    <dl class="hero-stats fade" style="--d:620ms">
      {hero.stats.map((s) => (
        <div class="stat">
          <dt class="stat-val">{s.value}</dt>
          <dd class="stat-lbl"><T es={s.label.es} en={s.label.en} /></dd>
        </div>
      ))}
    </dl>
  </div>

  <a class="scroll-cue fade" href="#sobre-mi" style="--d:760ms" aria-label="Scroll">
    <span class="scroll-line"></span>
    <span class="tlabel scroll-txt">scroll</span>
  </a>
</section>

<style>
  .hero {
    position: relative;
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: 72px;
    overflow: hidden;
  }
  .hero-inner { position: relative; z-index: 2; padding-block: clamp(2rem, 6vw, 4rem); }

  /* corner crosshairs */
  .cross {
    position: absolute;
    width: 18px; height: 18px;
    z-index: 1;
    opacity: 0.5;
  }
  .cross::before, .cross::after {
    content: ""; position: absolute; background: var(--accent);
  }
  .cross::before { left: 50%; top: 0; width: 1px; height: 100%; transform: translateX(-50%); }
  .cross::after  { top: 50%; left: 0; height: 1px; width: 100%; transform: translateY(-50%); }
  .cross-tl { top: 96px; left: var(--pad); }
  .cross-br { bottom: 64px; right: var(--pad); }

  .hero-kicker { margin-bottom: 1.6rem; }
  .status {
    display: inline-flex; align-items: center; gap: 0.55rem;
    font-size: 0.78rem; font-weight: 600; letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    padding: 0.4rem 0.85rem 0.4rem 0.7rem;
    border: 1px solid var(--line-2);
    border-radius: 999px;
    background: var(--card);
  }
  .status-dot {
    width: 8px; height: 8px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0%   { box-shadow: 0 0 0 0 var(--accent-glow); }
    70%  { box-shadow: 0 0 0 10px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .hero-title {
    font-family: var(--font-display);
    font-weight: 700;
    line-height: 0.92;
    letter-spacing: -0.02em;
    color: var(--text-strong);
    font-size: clamp(3.6rem, 15vw, 11rem);
    margin-bottom: 1.8rem;
  }
  .hero-title .line { display: block; }
  .hero-title .outline {
    position: relative;
    color: transparent;
    -webkit-text-stroke: 1.4px var(--text-strong);
  }
  .role-tag {
    display: inline-block;
    vertical-align: middle;
    margin-left: 1rem;
    -webkit-text-stroke: 0;
    color: var(--accent-ink);
    font-family: var(--font-body);
    font-weight: 600;
    font-size: clamp(0.7rem, 1.4vw, 0.92rem);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border-left: 2px solid var(--accent);
    padding-left: 0.8rem;
    line-height: 1.3;
    max-width: 220px;
    white-space: normal;
  }

  .hero-tag {
    max-width: 46ch;
    font-size: clamp(1.05rem, 2vw, 1.3rem);
    color: var(--muted);
    margin-bottom: 2.4rem;
    font-weight: 300;
  }

  .hero-cta { display: flex; flex-wrap: wrap; gap: 0.9rem; margin-bottom: 3.2rem; }

  .hero-stats {
    display: flex;
    gap: clamp(1.5rem, 5vw, 3.5rem);
    flex-wrap: wrap;
  }
  .stat { position: relative; padding-left: 1rem; }
  .stat::before {
    content: ""; position: absolute; left: 0; top: 4px; bottom: 4px;
    width: 2px; background: var(--accent); opacity: 0.6;
  }
  .stat-val {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: clamp(1.5rem, 3vw, 2.1rem);
    color: var(--text-strong);
    line-height: 1;
  }
  .stat-lbl {
    font-size: 0.8rem;
    color: var(--muted);
    margin-top: 0.35rem;
    letter-spacing: 0.02em;
  }

  .scroll-cue {
    position: absolute;
    bottom: 1.6rem; left: 50%;
    transform: translateX(-50%);
    display: flex; flex-direction: column; align-items: center; gap: 0.5rem;
    color: var(--muted);
  }
  .scroll-line {
    width: 1px; height: 40px;
    background: linear-gradient(var(--accent), transparent);
    position: relative; overflow: hidden;
  }
  .scroll-line::after {
    content: ""; position: absolute; top: -50%; left: 0;
    width: 100%; height: 50%;
    background: var(--accent);
    animation: scrolldot 1.8s var(--ease) infinite;
  }
  @keyframes scrolldot { 0% { top: -50%; } 100% { top: 100%; } }
  .scroll-txt { font-size: 0.6rem; }

  /* staggered entrance */
  .fade { opacity: 0; transform: translateY(18px); animation: fadeUp 0.9s var(--ease-out) forwards; animation-delay: var(--d, 0ms); }
  @keyframes fadeUp { to { opacity: 1; transform: none; } }
  @media (prefers-reduced-motion: reduce) {
    .fade { animation: none; opacity: 1; transform: none; }
    .status-dot, .scroll-line::after { animation: none; }
  }

  @media (max-width: 600px) {
    .role-tag { display: block; margin: 0.8rem 0 0; max-width: 100%; }
    .scroll-cue { display: none; }
  }
</style>
