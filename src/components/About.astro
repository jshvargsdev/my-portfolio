---
import { Image } from "astro:assets";
import { about, profile } from "../data/content";
import portrait from "../assets/foto-perfil.png";
import T from "./T.astro";
---
<section class="section about" id="sobre-mi">
  <div class="container">
    <div class="sec-head reveal">
      <span class="sec-index">01</span>
      <h2 class="sec-title"><T es={about.title.es} en={about.title.en} /></h2>
      <span class="sec-rule"></span>
    </div>

    <div class="about-grid">
      <!-- Portrait -->
      <figure class="portrait reveal">
        <div class="portrait-frame">
          <span class="pc pc-tl" aria-hidden="true"></span>
          <span class="pc pc-tr" aria-hidden="true"></span>
          <span class="pc pc-bl" aria-hidden="true"></span>
          <span class="pc pc-br" aria-hidden="true"></span>
          <Image
            class="portrait-img"
            src={portrait}
            alt={`${profile.name} — ${about.title.es}`}
            width={640}
            height={640}
            loading="lazy"
          />
          <figcaption class="portrait-tag">
            <span class="status-dot"></span>
            <T es={profile.location.es} en={profile.location.en} />
          </figcaption>
        </div>
      </figure>

      <!-- Body + meta -->
      <div class="about-content">
        <div class="about-body">
          {about.paragraphs.map((p, i) => (
            <p class="about-p reveal" style={`--d:${i * 90}ms`}>
              <T es={p.es} en={p.en} block />
            </p>
          ))}
        </div>

        <div class="about-meta">
          <div class="meta-card reveal">
            <span class="tlabel"><T es={about.focusLabel.es} en={about.focusLabel.en} /></span>
            <p class="meta-val"><T es={about.focus.es} en={about.focus.en} block /></p>
          </div>
          <div class="meta-card reveal" style="--d:90ms">
            <span class="tlabel"><T es={about.educationLabel.es} en={about.educationLabel.en} /></span>
            <p class="meta-val edu-degree"><T es={about.education.degree.es} en={about.education.degree.en} /></p>
            <p class="meta-sub"><T es={about.education.school.es} en={about.education.school.en} /> · {about.education.year}</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 320px 1fr;
    gap: clamp(2rem, 6vw, 4.5rem);
    align-items: start;
  }

  /* ---------- Portrait ---------- */
  .portrait { position: sticky; top: 100px; margin: 0; }
  .portrait-frame {
    position: relative;
    padding: 9px;
    border: 1px solid var(--line-2);
    border-radius: 20px;
    background: var(--card);
  }
  .portrait-img {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 1 / 1;
    object-fit: cover;
    border-radius: 13px;
    filter: grayscale(0.32) contrast(1.04) brightness(0.97);
    transition: filter 0.5s var(--ease), transform 0.6s var(--ease);
  }
  .portrait-frame:hover .portrait-img {
    filter: grayscale(0) contrast(1) brightness(1);
    transform: scale(1.012);
  }
  /* duotone-ish cyan wash that fades on hover */
  .portrait-frame::after {
    content: "";
    position: absolute;
    inset: 9px;
    border-radius: 13px;
    background: linear-gradient(150deg, transparent 40%, var(--accent-soft));
    mix-blend-mode: screen;
    opacity: 0.7;
    pointer-events: none;
    transition: opacity 0.5s var(--ease);
  }
  .portrait-frame:hover::after { opacity: 0; }

  /* corner crosshairs */
  .pc { position: absolute; width: 12px; height: 12px; z-index: 2; }
  .pc::before, .pc::after { content: ""; position: absolute; background: var(--accent); }
  .pc::before { left: 50%; top: 0; width: 1px; height: 100%; transform: translateX(-50%); }
  .pc::after  { top: 50%; left: 0; height: 1px; width: 100%; transform: translateY(-50%); }
  .pc-tl { top: -1px; left: -1px; }
  .pc-tr { top: -1px; right: -1px; }
  .pc-bl { bottom: -1px; left: -1px; }
  .pc-br { bottom: -1px; right: -1px; }

  .portrait-tag {
    position: absolute;
    left: 16px; bottom: 16px;
    display: inline-flex; align-items: center; gap: 0.5rem;
    font-size: 0.72rem; font-weight: 600; letter-spacing: 0.06em; text-transform: uppercase;
    color: var(--text-strong);
    padding: 0.4rem 0.7rem;
    border-radius: 999px;
    background: color-mix(in srgb, var(--bg) 70%, transparent);
    -webkit-backdrop-filter: blur(8px); backdrop-filter: blur(8px);
    border: 1px solid var(--line-2);
    z-index: 2;
  }
  .status-dot {
    width: 7px; height: 7px; border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 0 0 var(--accent-glow);
    animation: pulse 2.4s var(--ease) infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 var(--accent-glow); }
    70% { box-shadow: 0 0 0 9px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  /* ---------- Body ---------- */
  .about-content { display: flex; flex-direction: column; gap: 2rem; }
  .about-body { display: flex; flex-direction: column; gap: 1.4rem; }
  .about-p {
    font-size: clamp(1.15rem, 2.2vw, 1.5rem);
    line-height: 1.5;
    color: var(--text);
    font-weight: 300;
    letter-spacing: -0.005em;
  }

  .about-meta { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
  .meta-card {
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 1.3rem 1.4rem;
    background: var(--card);
    position: relative;
    overflow: hidden;
  }
  .meta-card::before {
    content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 2px;
    background: var(--accent); opacity: 0.7;
  }
  .meta-val {
    margin-top: 0.6rem; font-size: 1.02rem; color: var(--text-strong);
    font-weight: 600; line-height: 1.4;
  }
  .edu-degree { font-family: var(--font-display); font-weight: 700; }
  .meta-sub { margin-top: 0.3rem; font-size: 0.85rem; color: var(--muted); }

  @media (max-width: 860px) {
    .about-grid { grid-template-columns: 1fr; }
    .portrait { position: static; max-width: 340px; }
  }
  @media (max-width: 520px) {
    .about-meta { grid-template-columns: 1fr; }
  }
  @media (prefers-reduced-motion: reduce) {
    .status-dot { animation: none; }
  }
</style>
